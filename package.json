{
  "name": "blade-islands",
  "version": "0.2.0",
  "description": "Client-side island runtime for React, Vue, and Svelte in Laravel Blade. Maintained fork of eznix86/blade-islands.",
  "license": "MIT",
  "homepage": "https://github.com/akrista/blade-islands",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akrista/blade-islands.git"
  },
  "bugs": {
    "url": "https://github.com/akrista/blade-islands/issues"
  },
  "keywords": [
    "blade",
    "islands",
    "laravel",
    "react",
    "vue",
    "svelte",
    "vite"
  ],
  "author": {
    "name": "Bruno Bernard",
    "email": "contact.brunobernard@gmail.com",
    "url": "https://github.com/eznix86"
  },
  "contributors": [
    {
      "name": "Akrista",
      "url": "https://github.com/akrista"
    }
  ],
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "prettier --check ."
  },
  "exports": {
    "./react": "./src/react/index.js",
    "./vue": "./src/vue/index.js",
    "./svelte": "./src/svelte/index.js"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "svelte": ">=5",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^29.0.0",
    "prettier": "^3.6.0",
    "vitest": "^4.0.0"
  }
}
